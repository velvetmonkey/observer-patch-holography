{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floatingpragma.io/schemas/oph_bd_threshold_spectrum_inputs.schema.json",
  "title": "OPH BD threshold and spectrum source packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact",
    "schema_version",
    "issue",
    "bd_branch",
    "external_sources",
    "literature_inventory",
    "target_coordinates",
    "reference_inputs",
    "proxy_assumptions",
    "numerical_policy",
    "bd_uv_inputs"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "const": "oph_bd_threshold_spectrum_source_packet"
    },
    "schema_version": {
      "const": 1
    },
    "issue": {
      "const": 368
    },
    "bd_branch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identifier",
        "scope",
        "selected_hidden_completion",
        "selected_moduli_point"
      ],
      "properties": {
        "identifier": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "selected_hidden_completion": {"type": ["string", "null"]},
        "selected_moduli_point": {"type": ["string", "null"]}
      }
    },
    "external_sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/externalSource"}
    },
    "literature_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "not_supplied_by_published_bd_sources"],
      "properties": {
        "available": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bundle_moduli_count",
            "complex_structure_moduli_count",
            "hidden_completion_original",
            "kahler_moduli_count",
            "one_higgs_locus",
            "visible_massless_spectrum"
          ],
          "properties": {
            "bundle_moduli_count": {"type": "integer", "minimum": 0},
            "complex_structure_moduli_count": {"type": "integer", "minimum": 0},
            "hidden_completion_original": {"type": "string", "minLength": 1},
            "kahler_moduli_count": {"type": "integer", "minimum": 0},
            "one_higgs_locus": {"type": "string", "minLength": 1},
            "visible_massless_spectrum": {"type": "string", "minLength": 1}
          }
        },
        "not_supplied_by_published_bd_sources": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "target_coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alpha2_mz", "alphaY_mz", "mH_gev", "mt_gev", "v_gev"],
      "properties": {
        "alpha2_mz": {"$ref": "#/$defs/coordinateRecord"},
        "alphaY_mz": {"$ref": "#/$defs/coordinateRecord"},
        "mH_gev": {"$ref": "#/$defs/coordinateRecord"},
        "mt_gev": {"$ref": "#/$defs/coordinateRecord"},
        "v_gev": {"$ref": "#/$defs/coordinateRecord"}
      }
    },
    "reference_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alpha3_reference_mz", "mZ_reference_gev"],
      "properties": {
        "alpha3_reference_mz": {
          "allOf": [
            {"$ref": "#/$defs/coordinateRecord"},
            {"required": ["uncertainty"]}
          ]
        },
        "mZ_reference_gev": {"$ref": "#/$defs/coordinateRecord"}
      }
    },
    "proxy_assumptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alpha1_normalization",
        "gauge_loop_order",
        "m_susy_scan_gev",
        "mssm_beta_coefficients",
        "sm_beta_coefficients",
        "stop_mixing_scan",
        "tan_beta_scan"
      ],
      "properties": {
        "alpha1_normalization": {"const": "alpha_1=(5/3)alpha_Y"},
        "gauge_loop_order": {"const": 1},
        "m_susy_scan_gev": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "contains": {"const": "1000"},
          "items": {"$ref": "#/$defs/positiveDecimalString"}
        },
        "mssm_beta_coefficients": {
          "const": ["33/5", "1", "-3"]
        },
        "sm_beta_coefficients": {
          "const": ["41/10", "-19/6", "-7"]
        },
        "stop_mixing_scan": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["0", "sqrt(6)"]}
        },
        "tan_beta_scan": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/positiveDecimalString"}
        }
      }
    },
    "numerical_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decimal_precision_digits",
        "pi_decimal",
        "receipt_numbers",
        "rounding"
      ],
      "properties": {
        "decimal_precision_digits": {"const": 80},
        "pi_decimal": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
        "receipt_numbers": {"const": "decimal strings"},
        "rounding": {"const": "ROUND_HALF_EVEN"}
      }
    },
    "bd_uv_inputs": {
      "type": "object",
      "required": [
        "heavy_nonzero_mode_spectrum",
        "kahler_moduli_point_metric_and_mass_matrix",
        "complex_structure_moduli_point_and_mass_matrix",
        "bundle_moduli_point_and_mass_matrix",
        "dilaton_point_and_mass",
        "bulk_five_brane_sector_and_moduli_or_absence",
        "string_compactification_and_matching_scales",
        "hidden_sector_completion_and_spectrum",
        "normalized_yukawa_boundary_data",
        "supersymmetric_sector_decoupling_map",
        "conventional_susy_breaking_and_mediation_data",
        "conventional_soft_terms_boundary_conditions",
        "bd_equivalent_non_susy_uv_deformation_receipt",
        "low_energy_spectrum_solver_receipt",
        "threshold_matching_receipt",
        "physical_moduli_jacobian"
      ],
      "additionalProperties": false,
      "properties": {
        "heavy_nonzero_mode_spectrum": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "kahler_moduli_point_metric_and_mass_matrix": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "complex_structure_moduli_point_and_mass_matrix": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "bundle_moduli_point_and_mass_matrix": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "dilaton_point_and_mass": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "bulk_five_brane_sector_and_moduli_or_absence": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "string_compactification_and_matching_scales": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "hidden_sector_completion_and_spectrum": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "normalized_yukawa_boundary_data": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "supersymmetric_sector_decoupling_map": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "required": [
                "path",
                "sha256",
                "status",
                "route"
              ],
              "additionalProperties": false,
              "properties": {
                "path": {
                  "type": "string",
                  "pattern": "^(?!/)(?!.*\\.\\.).+$"
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "status": {
                  "const": "hash_and_envelope_verified"
                },
                "route": {
                  "enum": [
                    "conventional_susy_breaking",
                    "bd_equivalent_non_susy_uv_deformation"
                  ]
                }
              }
            }
          ]
        },
        "conventional_susy_breaking_and_mediation_data": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "conventional_soft_terms_boundary_conditions": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "bd_equivalent_non_susy_uv_deformation_receipt": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "low_energy_spectrum_solver_receipt": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "threshold_matching_receipt": {
          "$ref": "#/$defs/nullableReceipt"
        },
        "physical_moduli_jacobian": {
          "$ref": "#/$defs/nullableReceipt"
        }
      }
    }
  },
  "$defs": {
    "positiveDecimalString": {
      "type": "string",
      "pattern": "^(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?)$"
    },
    "localSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json_pointer", "path"],
      "properties": {
        "json_pointer": {"type": "string", "pattern": "^/"},
        "path": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.).+$"},
        "promotion_json_pointer": {"type": "string", "pattern": "^/"},
        "promotion_required_value": {"type": "boolean"}
      },
      "dependentRequired": {
        "promotion_json_pointer": ["promotion_required_value"],
        "promotion_required_value": ["promotion_json_pointer"]
      }
    },
    "coordinateRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_status", "value"],
      "properties": {
        "claim_status": {"type": "string", "minLength": 1},
        "external_source_id": {"type": "string", "minLength": 1},
        "local_source": {"$ref": "#/$defs/localSource"},
        "uncertainty": {"$ref": "#/$defs/positiveDecimalString"},
        "value": {"$ref": "#/$defs/positiveDecimalString"}
      },
      "oneOf": [
        {"required": ["local_source"]},
        {"required": ["external_source_id"]}
      ]
    },
    "externalSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "url"],
      "properties": {
        "arxiv_id": {"type": "string", "minLength": 1},
        "id": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1},
        "sha256_pdf": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "sha256_source_archive": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "url": {"type": "string", "pattern": "^https://"}
      },
      "oneOf": [
        {"required": ["sha256_pdf"]},
        {"required": ["sha256_source_archive"]}
      ]
    },
    "nullableReceipt": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "path",
            "sha256",
            "status"
          ],
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*\\.\\.).+$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "status": {
              "const": "hash_and_envelope_verified"
            }
          }
        }
      ]
    }
  }
}
